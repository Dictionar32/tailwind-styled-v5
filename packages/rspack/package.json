{
  "name": "@tailwind-styled/rspack",
  "version": "5.0.0",
  "description": "Rspack adapter for tailwind-styled-v4 — loader + plugin",
  "author": "Dictionar32",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.js",
      "require": "./dist/loader.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@tailwind-styled/compiler": "*",
    "@tailwind-styled/engine": "*"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsup": "^8"
  },
  "scripts": {
    "build": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts src/loader.ts --format cjs,esm --dts --out-dir dist --watch",
    "clean": "rm -rf dist"
  }
}
