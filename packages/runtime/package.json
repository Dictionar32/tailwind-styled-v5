{
  "name": "@tailwind-styled/runtime",
  "version": "5.0.0",
  "description": "Runtime helpers for tailwind-styled-v5 compound components",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --out-dir dist --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwind-styled/theme": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@tailwind-styled/theme": "*",
    "@types/react": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "sideEffects": false
}
