{
  "name": "@tailwind-styled/engine",
  "version": "5.0.0",
  "description": "Unified build engine for tailwind-styled-v4",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@tailwind-styled/analyzer": "^5.0.0",
    "@tailwind-styled/compiler": "^5.0.0",
    "@tailwind-styled/scanner": "^5.0.0",
    "@tailwind-styled/shared": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "tsup": "^8",
    "vitest": "^2"
  },
  "scripts": {
    "build": "tsup src/index.ts src/internal.ts --format cjs,esm --out-dir dist --clean --external typescript",
    "dev": "tsup src/index.ts src/internal.ts --format cjs,esm --out-dir dist --watch --external typescript",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
