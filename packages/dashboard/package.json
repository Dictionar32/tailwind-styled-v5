{
  "name": "@tailwind-styled/dashboard",
  "version": "5.0.0",
  "description": "Performance dashboard for benchmark and runtime metrics",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./src/server.mjs",
  "exports": {
    ".": {
      "types": "./src/server.d.ts",
      "import": "./src/server.mjs"
    }
  },
  "scripts": {
    "dev": "node src/server.mjs",
    "test": "node -e \"import('./src/server.mjs').then(()=>setTimeout(()=>process.exit(0),500))\"",
    "build": "echo \"No build step — ESM server runs directly\"",
    "start": "node src/server.mjs"
  }
}
