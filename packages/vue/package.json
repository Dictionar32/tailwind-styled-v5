{
  "name": "@tailwind-styled/vue",
  "version": "5.0.0",
  "description": "Vue 3 adapter for tailwind-styled-v4 \u2014 tw() components with variants",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "node --test test/vue-adapter.test.mjs"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "tailwind-merge": ">=2.0.0"
  },
  "devDependencies": {
    "vue": "^3.4.0",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "tailwind",
    "vue",
    "vue3",
    "styled-components",
    "variants",
    "css"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/tailwind-styled-v4"
  }
}
