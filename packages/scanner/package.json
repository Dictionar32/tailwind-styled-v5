{
  "name": "@tailwind-styled/scanner",
  "version": "5.0.0",
  "description": "Standalone class scanner for tailwind-styled-v4",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwind-styled/compiler": "*"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsup": "^8"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "dev": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --watch --external typescript",
    "clean": "rm -rf dist"
  }
}
