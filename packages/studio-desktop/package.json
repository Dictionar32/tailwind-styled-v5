{
  "name": "@tailwind-styled/studio-desktop",
  "version": "4.5.0",
  "description": "tailwind-styled Studio \u2014 Desktop app (Electron)",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron . --dev || echo \"[studio] Install electron: npm install -D electron\"",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --mac --win --linux",
    "build": "electron-builder --dir",
    "test": "echo \"Studio desktop tests require Electron \u2014 run: npm run start\"",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:all": "electron-builder --mac --win --linux",
    "pack": "electron-builder --dir",
    "postinstall": "echo \"Run: npm run dev to start Studio Desktop\""
  },
  "build": {
    "appId": "dev.tailwind-styled.studio",
    "productName": "tailwind-styled Studio",
    "copyright": "Copyright \u00a9 2026",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "!src/**/*.test.*"
    ],
    "extraResources": [
      {
        "from": "../../scripts/v45/studio.mjs",
        "to": "scripts/v45/studio.mjs"
      },
      {
        "from": "../../scripts/v45/ai.mjs",
        "to": "scripts/v45/ai.mjs"
      },
      {
        "from": "../../scripts/v49/split-routes.mjs",
        "to": "scripts/v49/split-routes.mjs"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "your-org",
      "repo": "tailwind-styled-v4"
    }
  },
  "dependencies": {
    "electron-updater": "^6.0.0",
    "@tailwind-styled/engine": "*",
    "@tailwind-styled/scanner": "*",
    "@tailwind-styled/shared": "*"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  }
}
