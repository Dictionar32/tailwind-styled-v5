{
  "name": "@tailwind-styled/testing",
  "version": "4.5.0",
  "description": "Testing matchers and helpers for tailwind-styled",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "test": "node --test test/testing-utils.test.mjs"
  }
}
