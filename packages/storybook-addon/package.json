{
  "name": "@tailwind-styled/storybook-addon",
  "version": "5.0.0",
  "description": "Storybook helpers for tailwind-styled variant previews",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsup": "^8",
    "vitest": "^2.0.0"
  }
}
