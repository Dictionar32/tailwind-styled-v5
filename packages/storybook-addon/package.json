{
  "name": "@tailwind-styled/storybook-addon",
  "version": "4.5.0",
  "description": "Storybook helpers for tailwind-styled variant previews",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean --external typescript",
    "test": "echo \"No automated tests \u2014 see storybook docs\""
  }
}
