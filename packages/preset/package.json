{
  "name": "@tailwind-styled/preset",
  "version": "5.0.0",
  "description": "Default Tailwind preset for tailwind-styled-v5 — v5 with Tailwind v4 CSS-first support",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./default": {
      "types": "./dist/defaultPreset.d.ts",
      "import": "./dist/defaultPreset.js",
      "require": "./dist/defaultPreset.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/defaultPreset.ts --format cjs,esm --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts src/defaultPreset.ts --format cjs,esm --dts --out-dir dist --watch"
  }
}
