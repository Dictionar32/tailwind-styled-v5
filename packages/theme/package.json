{
  "name": "@tailwind-styled/theme",
  "version": "5.0.0",
  "description": "Theme engine and live token engine for tailwind-styled-v5",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./live-tokens": {
      "types": "./dist/liveTokens.d.ts",
      "import": "./dist/liveTokens.js",
      "require": "./dist/liveTokens.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "*",
    "tsup": "*",
    "typescript": "*",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
