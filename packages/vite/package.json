{
  "name": "@tailwind-styled/vite",
  "version": "5.0.0",
  "description": "Vite plugin for tailwind-styled-v4 — compile-time transform, safelist generation",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/plugin.cjs",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@tailwind-styled/compiler": "^5.0.0",
    "@tailwind-styled/engine": "^5.0.0",
    "@tailwind-styled/scanner": "^5.0.0"
  },
  "peerDependencies": {
    "vite": ">=6.2.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "@types/node": "^20",
    "vitest": "^2"
  }
}
